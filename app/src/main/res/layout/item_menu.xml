<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_margin="4dp"
    android:background="@drawable/card_bg">
    <ImageView
        android:id="@+id/imgVegType"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:src="@drawable/ic_veg"/>

    <!-- Image Section -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgFoodItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/food"/>
        </androidx.cardview.widget.CardView>

        <!-- Veg / Non Veg Icon -->

    </FrameLayout>


    <!-- Food Name -->
    <TextView
        android:id="@+id/tvMenuName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Garlic Bread"
        android:paddingTop="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        style="@style/TextSemiBoldPoppins"/>


    <!-- Price -->
    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$5.00"
        android:textSize="12sp"
        style="@style/TextNormalPoppinsLightGray"/>


    <!-- Description (1 line with ...) -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fresh garlic bread with cheese and butter"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#888888"
        android:paddingTop="2dp"/>


    <!-- Quantity Controls -->
    <LinearLayout
        android:id="@+id/llQuantityControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp">

        <ImageButton
            android:id="@+id/btnMinus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:backgroundTint="@color/color_secondary"
            android:background="@drawable/btn_bg_round"
            android:src="@drawable/ic_minus"
            android:scaleType="centerInside"
            android:padding="6dp"
            app:tint="@color/black"/>

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:padding="8dp"
            style="@style/TextSemiBoldPoppins"/>

        <ImageButton
            android:id="@+id/btnPlus"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:backgroundTint="@color/color_secondary"
            android:background="@drawable/btn_bg_round"
            android:src="@drawable/ic_add"
            android:scaleType="centerInside"
            android:padding="6dp"
            app:tint="@color/black"/>

    </LinearLayout>

</LinearLayout>